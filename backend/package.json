{
  "name": "career-compass-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "lint": "eslint . --ext .js",
    "migrate": "for f in src/db/migrations/*.sql; do psql \"$DATABASE_URL\" -f \"$f\"; done",
    "seed": "node src/db/seed.js",
    "sync:adzuna": "node src/db/sync_adzuna.js",
    "seed:skills": "node src/db/seed_skills.js",
    "import:esco": "node src/db/import_esco.js",
    "import:onet": "node src/db/import_onet.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.6.0",
    "node-cache": "^5.1.2",
    "pg": "^8.12.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0"
  }
}
